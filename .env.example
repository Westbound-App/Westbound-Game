# -----------------------------------------------------------------------------
# WESTBOUND environment variables
# Copy to .env.local for local development. Never commit real secrets.
# -----------------------------------------------------------------------------

# Public site URL used for share cards / absolute OG images
NEXT_PUBLIC_SITE_URL=https://harmonious-melba-73601b.netlify.app

# Supabase (required for shared live state / auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: default game slug for the live page
NEXT_PUBLIC_DEFAULT_GAME_SLUG=sandbox-portland

# Phase 2+ (leave empty for Phase A)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Routing provider keys (Phase 2+)
# MAPBOX_ACCESS_TOKEN=

# Google Street View Static API (server-only — enables road camera imagery)
# Enable "Street View Static API" in Google Cloud, then:
# GOOGLE_MAPS_API_KEY=
